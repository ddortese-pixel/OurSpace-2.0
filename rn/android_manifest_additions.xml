<!--
  OurSpace 2.0 — Complete AndroidManifest.xml
  ─────────────────────────────────────────────────────────────────────────────
  Copy the PERMISSIONS block inside your <manifest> tag.
  Copy the SERVICES block inside your <application> tag.
  Your file: android/app/src/main/AndroidManifest.xml
-->

<!-- ═══════════════════════════════════════════════════════════════════════════
     PERMISSIONS — add these inside <manifest> before <application>
     ═══════════════════════════════════════════════════════════════════════════ -->

    <!-- Network -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />

    <!-- Media (WebRTC / Daily.co) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-permission android:name="android.permission.BLUETOOTH" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <!-- Notifications -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Wake screen for incoming call (over lock screen) -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <!-- Foreground Service — keeps polling alive when app is killed -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_PHONE_CALL" />

    <!-- Battery optimization exemption (VoIP exception per Google policy) -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Restart service after device reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Native call UI (ConnectionService) via react-native-callkeep -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.MANAGE_OWN_CALLS" />


<!-- ═══════════════════════════════════════════════════════════════════════════
     SERVICES — add these inside <application>
     ═══════════════════════════════════════════════════════════════════════════ -->

    <!-- react-native-callkeep: Android ConnectionService (native call UI) -->
    <service
        android:name="io.wazo.callkeep.VoiceConnectionService"
        android:label="@string/app_name"
        android:permission="android.permission.BIND_TELECOM_CONNECTION_SERVICE"
        android:exported="true">
        <intent-filter>
            <action android:name="android.telecom.ConnectionService" />
        </intent-filter>
    </service>

    <!-- @notifee/react-native: Foreground Service for ongoing calls + polling -->
    <service
        android:name="app.notifee.core.ForegroundService"
        android:foregroundServiceType="phoneCall"
        android:exported="false" />

    <!-- Boot receiver: restart foreground service after device reboot -->
    <!-- Uncomment if you add a BootReceiver native module -->
    <!--
    <receiver
        android:name=".BootReceiver"
        android:exported="true">
        <intent-filter>
